import { z } from "zod";

const envSchema = z.object({
  // App
  NEXT_PUBLIC_APP_URL: z.string().url({
    message: "NEXT_PUBLIC_APP_URL must be a valid URL (e.g. http://localhost:3000)",
  }),
{{if .HasAuth}}
  // Better Auth
  BETTER_AUTH_SECRET: z.string().min(32, {
    message: "BETTER_AUTH_SECRET must be at least 32 characters. Generate one with: openssl rand -base64 32",
  }),
  BETTER_AUTH_URL: z.string().url({
    message: "BETTER_AUTH_URL must be a valid URL (e.g. http://localhost:3000)",
  }),
{{end}}
{{if .HasGitHub}}
  // GitHub OAuth
  GITHUB_CLIENT_ID: z.string().min(1, {
    message: "GITHUB_CLIENT_ID is required for GitHub OAuth. Get it from https://github.com/settings/applications",
  }),
  GITHUB_CLIENT_SECRET: z.string().min(1, {
    message: "GITHUB_CLIENT_SECRET is required for GitHub OAuth.",
  }),
{{end}}
{{if .HasDB}}
  // Database
  DATABASE_URL: z.string().min(1, {
    message: "DATABASE_URL is required.{{if .IsSQLite}} Example: file:./dev.db{{end}}{{if .IsPostgres}} Example: postgresql://user:password@localhost:5432/dbname{{end}}{{if .IsMySQL}} Example: mysql://root:@127.0.0.1:3306/dbname{{end}}",
  }),
{{end}}
});

function validateEnv() {
  const result = envSchema.safeParse(process.env);

  if (!result.success) {
    const errors = result.error.issues
      .map((issue) => `  ✗ ${issue.path.join(".")}: ${issue.message}`)
      .join("\n");

    console.error("\n\n🚨 Invalid environment variables:\n");
    console.error(errors);
    console.error("\nFix the above errors in your .env.local file and restart the server.\n\n");

    throw new Error("Invalid environment variables — see above for details.");
  }

  return result.data;
}

export const env = validateEnv();

export type Env = z.infer<typeof envSchema>;